{
  "version": 2,
  "builds": [
    {
      "src": "blog-project-starter-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "blog-project-starter-backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "blog-project-starter-backend/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "blog-project-starter-frontend/build/index.html"
    }
  ]
}